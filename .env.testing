# Placeholder env vars for `go test`. All values are fake — no real
# services are touched. Several packages call log.Fatalf in init() if
# these are missing; setting them lets the package load.
#
# Used by:
#   - bin/devenv-test (docker-compose overlay) via env_file in
#     infra/docker/docker-compose.testing.yml
#   - .github/workflows/testing.yml (loaded into $GITHUB_ENV)
#
# Real configs live in .env.development / .env.production (gitignored).

ENV=testing

# config/tripbot
CHANNEL_NAME=test
BOT_USERNAME=test
EXTERNAL_URL=http://localhost
GOOGLE_APPS_PROJECT_ID=test
GOOGLE_MAPS_API_KEY=test
TRIPBOT_HTTP_AUTH=test
VLC_SERVER_HOST=http://localhost:8081

# config/vlc-server (and shared)
VIDEO_DIR=/tmp
RUN_DIR=/tmp

# database
DATABASE_USER=test
DATABASE_DB=test
DATABASE_HOST=localhost

# twitch
TWITCH_AUTH_TOKEN=test
TWITCH_CLIENT_ID=test
TWITCH_CLIENT_SECRET=test

# helpers/sms (Twilio)
TWILIO_ACCT_SID=test
TWILIO_AUTH_TOKEN=test
TWILIO_FROM_NUM=test
TWILIO_TO_NUM=test
