# wayvnc config. Rendered by entrypoint.sh from this template — env
# substitution writes the final cfg to $XDG_RUNTIME_DIR/wayvnc.cfg
# where start-wayvnc.sh reads it.
#
# The TLS cert + key are generated by entrypoint.sh per pod start and
# live in $XDG_RUNTIME_DIR. Paths below match.

address=0.0.0.0
port=5900

# enable_auth=true is the load-bearing toggle: without it, the cert /
# key paths are read-but-ignored and wayvnc only offers RFB security
# type 1 (None) — which macOS Screen Sharing.app refuses. With it
# true, wayvnc requires a username+password handshake and brings in
# the encrypted security types listed below.
enable_auth=true

# Credentials live in the rendered cfg (envsubst'd from VNC_USERNAME +
# VNC_PASSWD). Plain-text in a root-owned file inside $XDG_RUNTIME_DIR
# (tmpfs at /tmp, no persistence) — same posture as the previous
# x11vnc -passwd setup. Defaults set in entrypoint.sh; override at
# deploy time by setting the env vars on the OBS Deployment.
username=${VNC_USERNAME}
password=${VNC_PASSWD}

# Self-signed cert generated per pod start (10y validity, RSA-2048,
# CN=wayvnc). VeNCrypt clients (TigerVNC, RealVNC) will see a
# "Verify Certificate" prompt the first time they connect.
private_key_file=/tmp/runtime-root/wayvnc.key
certificate_file=/tmp/runtime-root/wayvnc.crt

# relax_encryption=true enables Apple Diffie-Hellman (RFB security
# type 30) — that's the security type macOS Screen Sharing.app
# negotiates by preference. Without this, Screen Sharing.app fails to
# find a compatible security type and errors with "Unable to
# communicate with localhost". The "relax" name is wayvnc's framing:
# encryption is required for the credential exchange but the
# post-auth pixel stream can run unencrypted. Acceptable for our
# debug-only, port-forwarded VNC posture.
relax_encryption=true
