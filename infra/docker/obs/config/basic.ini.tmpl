[General]
Name=ADanaLife
[Video]
BaseCX=1920
BaseCY=1080
OutputCX=${OBS_OUTPUT_WIDTH}
OutputCY=${OBS_OUTPUT_HEIGHT}
FPSCommon=${OBS_FPS_COMMON}
; bilinear is OBS's default and what we implicitly had before #489
; introduced the templatized Output dims. lanczos here costs ~5-10x more
; CPU per scaled frame than bilinear and tips the (software-only, no
; GPU passthrough) compositor over its frame budget on stage, which in
; turn causes per-frame render buffers to backlog and grow OBS RSS by
; ~10 MB/min until the pod OOMs. Quality delta is invisible on motion.
ScaleType=bilinear
[Output]
Mode=Advanced
[AdvOut]
Encoder=${OBS_STREAM_ENCODER}
RecType=Standard
RecEncoder=none
TrackIndex=1
RecTrackIndex=1
Track1Bitrate=${OBS_AUDIO_BITRATE}
ApplyServiceSettings=true
[Audio]
SampleRate=48000
