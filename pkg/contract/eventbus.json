{
  "_comment": "Generated from pkg/eventbus via `go generate ./pkg/contract` — do not hand-edit. The NATS subject + envelope registry tripbot publishes and tripbot-console consumes; payload schemas are JSON Schema (draft 2020-12).",
  "subject_pattern": "tripbot.{env}.{domain}.{event}",
  "subjects": {
    "chat_message": {
      "subject": "tripbot.{env}.chat.message",
      "transport": "jetstream",
      "stream": "TRIPBOT_CHAT",
      "schema": {
        "type": "object",
        "title": "ChatMessage",
        "properties": {
          "platform": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "username",
          "text",
          "emitted_at"
        ]
      }
    },
    "chat_subscriber": {
      "subject": "tripbot.{env}.chat.subscriber",
      "transport": "core",
      "schema": {
        "type": "object",
        "title": "SubscriberEvent",
        "properties": {
          "platform": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          },
          "months": {
            "type": "integer"
          },
          "streak": {
            "type": "integer"
          },
          "gift_count": {
            "type": "integer"
          },
          "is_anonymous": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "kind",
          "username",
          "emitted_at"
        ]
      }
    },
    "viewers_count": {
      "subject": "tripbot.{env}.viewers.count",
      "transport": "core",
      "schema": {
        "type": "object",
        "title": "ViewerCount",
        "properties": {
          "platform": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "count",
          "emitted_at"
        ]
      }
    },
    "video_changed": {
      "subject": "tripbot.{env}.video.changed",
      "transport": "jetstream",
      "stream": "TRIPBOT_VIDEO",
      "schema": {
        "type": "object",
        "title": "VideoChanged",
        "properties": {
          "platform": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "flagged": {
            "type": "boolean"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "file",
          "state",
          "flagged",
          "lat",
          "lng",
          "emitted_at"
        ]
      }
    },
    "auth_status": {
      "subject": "tripbot.{env}.auth.status.{platform}",
      "wildcard": "tripbot.{env}.auth.status.*",
      "transport": "jetstream",
      "stream": "TRIPBOT_AUTH",
      "schema": {
        "type": "object",
        "title": "AuthStatus",
        "properties": {
          "platform": {
            "type": "string"
          },
          "accounts": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/AuthAccount"
            }
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "platform",
          "accounts",
          "emitted_at"
        ]
      }
    },
    "youtube_broadcast": {
      "subject": "tripbot.{env}.youtube.broadcast",
      "transport": "jetstream",
      "stream": "TRIPBOT_YOUTUBE",
      "schema": {
        "type": "object",
        "title": "YoutubeBroadcast",
        "properties": {
          "video_id": {
            "type": "string"
          },
          "live": {
            "type": "boolean"
          },
          "privacy": {
            "type": "string"
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "video_id",
          "live",
          "privacy",
          "emitted_at"
        ]
      }
    },
    "facebook_broadcast": {
      "subject": "tripbot.{env}.facebook.broadcast",
      "transport": "jetstream",
      "stream": "TRIPBOT_FACEBOOK",
      "schema": {
        "type": "object",
        "title": "FacebookBroadcast",
        "properties": {
          "video_id": {
            "type": "string"
          },
          "live": {
            "type": "boolean"
          },
          "privacy": {
            "type": "string"
          },
          "broadcast_id": {
            "type": "string"
          },
          "permalink_url": {
            "type": "string"
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "video_id",
          "live",
          "privacy",
          "broadcast_id",
          "permalink_url",
          "emitted_at"
        ]
      }
    }
  },
  "$defs": {
    "AuthAccount": {
      "type": "object",
      "title": "AuthAccount",
      "properties": {
        "account": {
          "type": "string"
        },
        "login_as": {
          "type": "string"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "account"
      ]
    }
  }
}
